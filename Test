<!DOCTYPE html>
<html lang="nl" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GadgetLine B.V. | Global Sourcing Corridor</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
    </style>
</head>
<body class="bg-white text-neutral-950 antialiased">

    <!-- NAVIGATIE -->
    <header class="bg-white/90 backdrop-blur-md border-b border-neutral-200/80 sticky top-0 z-50">
        <div class="max-w-6xl mx-auto px-6 py-6 flex items-center justify-between">
            <a href="index.html" class="block">
                <img src="logo.png" alt="GadgetLine B.V." class="h-12 md:h-20 w-auto object-contain">
            </a>
            
            <!-- Hamburger Knop -->
            <button id="menu-btn" class="md:hidden text-neutral-950 p-2">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
            </button>

            <!-- Navigatie menu -->
            <nav id="mobile-nav" class="hidden md:flex flex-col md:flex-row absolute md:static top-full left-0 w-full bg-white border-b border-neutral-200 p-6 md:p-0 gap-6 md:gap-8 items-center text-xs font-bold uppercase tracking-wider text-neutral-600">
                <a href="#profiel" class="hover:text-blue-600 transition">Bedrijfsprofiel</a>
                <a href="#netwerk" class="hover:text-blue-600 transition">Greater Bay Area</a>
                <a href="#producten" class="hover:text-blue-600 transition">Productgroepen</a>
                <a href="investors.html" class="text-blue-600 hover:text-blue-800 transition">Bedrijfsgegevens</a>
                <a href="#contact" class="hover:text-blue-600 transition">Contact</a>
            </nav>
        </div>
    </header>

    <!-- BEDRIJFSPROFIEL -->
    <section id="profiel" class="relative bg-gradient-to-br from-neutral-50 via-white to-neutral-100/40 py-24 border-b border-neutral-200/60 overflow-hidden">
        <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
            <div class="md:col-span-7 space-y-6">
                <span class="text-[10px] font-bold tracking-[0.2em] text-blue-600 uppercase bg-blue-50 border border-blue-200/50 px-3 py-1 rounded-full">Commercial Sourcing Partner</span>
                <h1 class="text-4xl md:text-6xl font-extrabold text-neutral-950 tracking-tight leading-[1.1]">
                    Directe Inkoop. <br><span class="text-neutral-400 font-light">Waterdichte Compliance.</span>
                </h1>
                <p class="text-base text-neutral-500 font-normal max-w-xl leading-relaxed">
                    GadgetLine B.V. optimaliseert de handelsstroom tussen vooraanstaande Aziatische fabrikanten en de Europese zakelijke markt. Wij treden op als strategisch architect van uw supply chain: van fabrieksaudits tot volledige EU-productcertificering, zonder onnodige tussenschakels.
                </p>
                <div class="pt-2">
                    <a href="#producten" class="bg-neutral-950 text-white text-xs font-bold px-6 py-4 rounded-lg hover:bg-neutral-800 transition uppercase tracking-wider shadow-sm">Ontdek Productlijnen</a>
                </div>
            </div>
            <div class="md:col-span-5 relative">
                <div class="absolute inset-0 bg-blue-500/5 rounded-3xl blur-2xl transform translate-x-4 translate-y-4"></div>
                <img src="https://images.unsplash.com/photo-1578575437130-527eed3abbec?auto=format&fit=crop&w=800&q=80" alt="Global Trade Hub" class="w-full h-80 md:h-[380px] object-cover rounded-2xl shadow-lg relative z-10 border border-neutral-200">
            </div>
        </div>
    </section>

    <!-- GREATER BAY AREA INTEGRATIE -->
    <section id="netwerk" class="py-20 bg-neutral-50 border-b border-neutral-200/60">
        <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">
            <div class="order-2 md:order-1">
                <img src="https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?auto=format&fit=crop&w=800&q=80" alt="Greater Bay Area Supply Chain" class="w-full h-80 object-cover rounded-2xl border border-neutral-200 shadow-sm">
            </div>
            <div class="space-y-4 order-1 md:order-2">
                <span class="text-[10px] font-bold tracking-[0.2em] text-neutral-400 uppercase">Sterke Supply Chain</span>
                <h2 class="text-3xl font-bold tracking-tight text-neutral-950">Integratie met de Greater Bay Area</h2>
                <p class="text-xs text-neutral-600 leading-relaxed">
                    GadgetLine B.V. verbindt de ongeëvenaarde productie- en innovatiekracht van de Greater Bay Area – met de focus op tech-hub Shenzhen – rechtstreeks met ons Nederlandse kantoor in de EU. 
                </p>
            </div>
        </div>
    </section>

    <!-- PRODUCTGROEPEN -->
    <section id="producten" class="py-24 max-w-6xl mx-auto px-6">
        <div class="mb-16">
            <h2 class="text-3xl font-bold tracking-tight text-neutral-950 mt-1">Gecureerde Categorieën</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div onclick="openModal('outdoor')" class="group bg-neutral-50 rounded-2xl border border-neutral-200/80 overflow-hidden cursor-pointer shadow-sm p-8">
                <h3 class="text-base font-bold text-neutral-950">Outdoor & Survival Gear</h3>
            </div>
            <div onclick="openModal('electronics')" class="group bg-neutral-50 rounded-2xl border border-neutral-200/80 overflow-hidden cursor-pointer shadow-sm p-8">
                <h3 class="text-base font-bold text-neutral-950">Consumer Electronics</h3>
            </div>
            <div onclick="openModal('fitness')" class="group bg-neutral-50 rounded-2xl border border-neutral-200/80 overflow-hidden cursor-pointer shadow-sm p-8">
                <h3 class="text-base font-bold text-neutral-950">Sport & Fitness Equipment</h3>
            </div>
        </div>
    </section>

    <!-- MODAL -->
    <div id="detailModal" class="fixed inset-0 bg-neutral-950/70 backdrop-blur-md z-50 hidden flex items-center justify-center p-4">
        <div class="bg-white max-w-3xl w-full rounded-2xl shadow-2xl p-8">
            <h3 id="modalTitle" class="text-lg font-bold mb-4"></h3>
            <button onclick="closeModal()" class="text-neutral-500">Sluiten</button>
        </div>
    </div>

    <!-- CONTACT -->
    <section id="contact" class="bg-neutral-50 py-24">
        <div class="max-w-xl mx-auto px-6">
            <h2 class="text-2xl font-bold text-center mb-10">Neem Contact Op</h2>
            <form action="https://formspree.io/f/sales@gadgetline.nl" method="POST" class="space-y-5 bg-white p-8 rounded-2xl border border-neutral-200">
                <input type="text" name="name" placeholder="Naam" required class="w-full border rounded-lg px-4 py-2.5 text-xs">
                <button type="submit" class="w-full bg-neutral-950 text-white text-xs font-bold py-3.5 rounded-lg">Verzenden</button>
            </form>
        </div>
    </section>

    <!-- SCRIPT -->
    <script>
        // Menu Toggle
        const menuBtn = document.getElementById('menu-btn');
        const mobileNav = document.getElementById('mobile-nav');
        menuBtn.onclick = () => mobileNav.classList.toggle('hidden');

        // Modal Logic
        function openModal(key) {
            document.getElementById('detailModal').classList.remove('hidden');
        }
        function closeModal() {
            document.getElementById('detailModal').classList.add('hidden');
        }
    </script>
</body>
</html>
